FROM nvidia/cuda:11.8.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV SHELL=/bin/bash
ENV NB_USER=jovyan
ENV NB_UID=1000
ENV NB_GID=100

RUN sed -i 's|http://archive.ubuntu.com/ubuntu|https://archive.ubuntu.com/ubuntu|g; s|http://security.ubuntu.com/ubuntu|https://security.ubuntu.com/ubuntu|g' /etc/apt/sources.list

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    git \
    curl \
    ca-certificates \
    tini \
    sudo \
    && rm -rf /var/lib/apt/lists/*

RUN if ! getent group ${NB_GID} >/dev/null; then groupadd -g ${NB_GID} ${NB_USER}; fi && \
    if ! id -u ${NB_USER} >/dev/null 2>&1; then useradd -m -s /bin/bash -N -u ${NB_UID} ${NB_USER}; fi && \
    usermod -g ${NB_GID} ${NB_USER} && \
    mkdir -p /home/${NB_USER}/work && \
    chown -R ${NB_UID}:${NB_GID} /home/${NB_USER}

RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel

RUN pip install --no-cache-dir \
    jupyterlab \
    notebook \
    jupyterhub \
    ipywidgets \
    numpy \
    pandas \
    matplotlib \
    scipy

# PyTorch CUDA版
RUN pip install --no-cache-dir \
    torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu118

WORKDIR /home/${NB_USER}
USER ${NB_UID}

EXPOSE 8888

CMD ["tini", "-g", "--", "jupyter", "lab", "--ip=0.0.0.0", "--no-browser", "--ServerApp.allow_origin=*", "--ServerApp.token="]
